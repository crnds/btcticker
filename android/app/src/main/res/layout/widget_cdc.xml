<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <!-- Top row: label (left), refresh button (right) -->
    <TextView
        android:id="@+id/widget_cdc_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_cdc_label"
        android:textColor="#555555"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <ImageButton
        android:id="@+id/widget_cdc_refresh_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@null"
        android:src="@drawable/ic_widget_refresh"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:contentDescription="@string/widget_refresh" />

    <!-- CDC strip bitmap fills the remaining space below the label row -->
    <ImageView
        android:id="@+id/widget_cdc_strip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/widget_cdc_label"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:scaleType="fitXY"
        android:adjustViewBounds="false" />

</RelativeLayout>
