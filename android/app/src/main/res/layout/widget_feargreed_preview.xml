<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the widget picker (previewLayout, API 31+). -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="Fear &amp; Greed"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="10sp" />

    <ImageButton
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@null"
        android:src="@drawable/ic_widget_refresh"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:contentDescription="@string/widget_refresh" />

    <TextView
        android:id="@+id/preview_fg_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="72"
        android:textColor="#69f0ae"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:textSize="22sp"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/preview_fg_value"
        android:text="Greed"
        android:textColor="#94a3b8"
        android:textSize="8sp"
        android:fontFamily="monospace"
        android:gravity="center" />

</RelativeLayout>
