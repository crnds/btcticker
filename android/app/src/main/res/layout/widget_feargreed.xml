<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg">

    <!-- Full-widget gauge bitmap (title + arc + dot + value + label rendered together) -->
    <ImageView
        android:id="@+id/widget_fg_gauge"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- Refresh button overlaid top-right -->
    <ImageButton
        android:id="@+id/widget_fg_refresh_btn"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@null"
        android:src="@drawable/ic_widget_refresh"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="8dp"
        android:contentDescription="@string/widget_refresh" />

</RelativeLayout>
