<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the widget picker (previewLayout, API 31+). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="10dp">

    <!-- Left pane preview -->
    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="104,888"
            android:textColor="#e0e0e0"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:textSize="28sp"
            android:maxLines="1"
            android:gravity="start|center_vertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:text="+6%"
            android:textColor="#00e676"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </RelativeLayout>

    <!-- Divider — TextView instead of View for RemoteViews compatibility -->
    <TextView
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:background="#1f1f1f" />

    <!-- Right pane preview -->
    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <TextView
            android:id="@+id/preview_combined_cdc_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:text="CDC · just now"
            android:textColor="#555555"
            android:textSize="9sp"
            android:fontFamily="monospace" />

        <ImageButton
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_widget_refresh"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:contentDescription="@string/widget_refresh" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/preview_combined_cdc_label"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="3dp"
            android:src="@drawable/ic_cdc_preview_bars"
            android:scaleType="fitXY" />

    </RelativeLayout>

</LinearLayout>
