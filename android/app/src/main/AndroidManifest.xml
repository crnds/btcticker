<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Price widget -->
        <receiver
            android:name=".PriceWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.PRICE_WIDGET_REFRESH" />
                <action android:name="com.btcticker.app.PRICE_WIDGET_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_price_info" />
        </receiver>

        <!-- CDC strip widget -->
        <receiver
            android:name=".CdcWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.CDC_WIDGET_REFRESH" />
                <action android:name="com.btcticker.app.CDC_WIDGET_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_cdc_info" />
        </receiver>

        <!-- Price widget 1×1 -->
        <receiver
            android:name=".PriceWidgetSmallProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.PRICE_WIDGET_SMALL_REFRESH" />
                <action android:name="com.btcticker.app.PRICE_WIDGET_SMALL_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_price_small_info" />
        </receiver>

        <!-- CDC strip widget 1×1 -->
        <receiver
            android:name=".CdcWidgetSmallProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.CDC_WIDGET_SMALL_REFRESH" />
                <action android:name="com.btcticker.app.CDC_WIDGET_SMALL_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_cdc_small_info" />
        </receiver>

        <!-- Combined price + CDC widget 2×1 -->
        <receiver
            android:name=".CombinedWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.COMBINED_WIDGET_REFRESH" />
                <action android:name="com.btcticker.app.COMBINED_WIDGET_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_combined_info" />
        </receiver>

        <!-- Mini combined price + CDC widget 1×1 -->
        <receiver
            android:name=".MiniCombinedWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.btcticker.app.MINI_COMBINED_WIDGET_REFRESH" />
                <action android:name="com.btcticker.app.MINI_COMBINED_WIDGET_MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_mini_combined_info" />
        </receiver>

        <!-- Restores alarms after device reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
</manifest>
